# ============================================================
# Skandia Monitor — Variables de Entorno
# Copia este archivo a .env y completa los valores reales
# NUNCA subas .env a git
# ============================================================

# --- Credenciales Skandia ---
SKANDIA_USER=1011089005
SKANDIA_PASSWORD=TU_CONTRASENA_AQUI
# URL del portal de clientes Skandia (actualiza si cambia)
SKANDIA_URL=https://www.skandia.com.co/

# --- Google Sheets (opcional, para backup) ---
# ID de tu hoja: docs.google.com/spreadsheets/d/ESTE_ID/edit
GOOGLE_SHEETS_ID=

# JSON completo del service account de Google Cloud
# Pégalo en una sola línea sin saltos de línea
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Turso (base de datos gratis) ---
# LOCAL: deja file:data/skandia.db  — no necesitas cuenta
# RENDER: ve a turso.tech → crear DB → copiar URL y token
TURSO_DATABASE_URL=file:data/skandia.db
TURSO_AUTH_TOKEN=

# --- Configuración App ---
PORT=3000
NODE_ENV=development

# Clave de 32 caracteres para cifrado en DB
# Genera una: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_KEY=cambia-esto-por-32-chars-random!!

# --- Cron (por defecto: 7AM Bogotá lunes-viernes) ---
# Usa timezone America/Bogota en node-cron, formato estándar cron
CRON_SCHEDULE=0 7 * * 1-5

# --- Debug (true = headless:false + screenshots) ---
DEBUG=false
